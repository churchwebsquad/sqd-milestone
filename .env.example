VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_CLICKUP_API_TOKEN=your-clickup-api-token-here

# Server-side only — never expose to the React frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
CRON_SECRET=your-random-secret-string-here
CLICKUP_MILESTONE_API_TOKEN=your-clickup-milestone-token-here

# n8n webhooks
VITE_N8N_TRIAGE_WEBHOOK_URL=https://your-n8n-instance/webhook/other-workflow
# Server-side only — proxied through /api/webhook/reply-triage to avoid CORS
N8N_REPLY_TRIAGE_WEBHOOK_URL=https://your-n8n-instance/webhook/reply-triage

# SRP (Sermon Reel Pipeline) — server-side only, n8n integration
# These power /api/srp/start-transcription and /api/srp/start-clipcutter.
# Without them, the SRP "Fetch transcript" / "Generate clips" steps will
# 500 with "SRP_N8N_*_WEBHOOK_URL not configured". The callback secret
# is a shared bearer that n8n sends back on every callback (transcription
# AND clipcutter) — same value for both workflows.
SRP_N8N_TRANSCRIPTION_WEBHOOK_URL=https://your-n8n-instance/webhook/srp-transcription
SRP_N8N_CLIPCUTTER_WEBHOOK_URL=https://your-n8n-instance/webhook/srp-clipcutter
SRP_N8N_CALLBACK_SECRET=your-random-shared-secret-here
